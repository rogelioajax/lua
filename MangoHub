local Players = game:GetService("Players")
local player = Players.LocalPlayer
local function showWelcomeMessage()

	local message = "Hey There! Welcome back " .. player.DisplayName
	local function typeWriter(text, delay)
		WelcomeTitle.Text = ""
		for i = 1, #text do
			WelcomeTitle.Text = WelcomeTitle.Text .. string.sub(text, i, i)
			wait(delay)
		end
	end
	typeWriter(message, 0.1)
end
showWelcomeMessage()
wait(3)
local function showInfoMessage()

	local message = "This is Isaac, the creator of MANGO. Due to the upcoming numerous ways to exploit, we have decided to return! We will be working hard and smart to achieve our goal, our script has gone through a lot, and today more than ever, we need your patience to achieve great things. MANGO will be updated like never before!"
	local function typeWriter(text, delay)
		InformationTitle.Text = ""
